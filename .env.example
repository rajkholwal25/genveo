# Supabase project
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Database — use the Supabase "Session pooler" connection string (IPv4-compatible).
# Encode @ in the password as %40.
DATABASE_URL=postgresql://postgres.YOUR-REF:YOUR-PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Transactional email (password reset)
RESEND_API_KEY=re_xxx
# Optional: verified sender (defaults to onboarding@resend.dev in sandbox)
# MAIL_FROM=Genveo <noreply@yourdomain.com>

# Flask
SECRET_KEY=change-me-to-a-long-random-string

# Force local SQLite instead of Supabase (optional)
# USE_SQLITE=1
